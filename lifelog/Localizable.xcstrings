            "value": "\n【分析対象データ】\n"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "【분석 대상 데이터】"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "[待分析数据]"
          }
        },
        "zh-Hant": {
