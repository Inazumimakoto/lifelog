        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "시작/종료 일시를 설정하면 Today나 캘린더의 타임라인에 반영됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
