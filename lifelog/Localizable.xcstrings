    "【分析の制約とルール】\n": {
      "comment": "Literal from lifelog/Services/PromptGenerator.swift",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "[Analysis constraints and rules]"
          }
        },
        "ja": {
          "stringUnit": {
