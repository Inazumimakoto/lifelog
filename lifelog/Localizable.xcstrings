        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "변덕스러운 고양이 관점에서 치유의 조언을줍니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "他从一只异想天开的猫的角度给出了治疗建议。"
