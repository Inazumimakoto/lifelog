        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "일정은 캘린더와 홈에서 공유됩니다. 외부 캘린더 일정은 수정할 수 없습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "事件在日历和主页上共享。外部日历上的事件无法编辑。"
