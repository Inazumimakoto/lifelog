    "💡 メールアドレスは使用しないので「非公開」がおすすめ": {
      "comment": "Literal from lifelog/Views/LetterSharing/InviteSignInFlowView.swift",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "💡 We recommend “Private” as your email address will not be used."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "💡 メールアドレスは使用しないので「非公開」がおすすめ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "💡 메일 주소는 사용하지 않으므로 \"비공개\"가 추천"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "💡 我们建议“私人”，因为您的电子邮件地址不会被使用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "💡 我們建議“私人”，因為您的電子郵件地址不會被使用。"
          }
        }
      }
    },
    "💡 時間帯を指定しない場合、終日いつでも届く可能性があります": {
      "comment": "Literal from lifelog/Views/Letter/LetterEditorView.swift",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "💡 If you don't specify a time slot, it may arrive at any time of the day"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "💡 時間帯を指定しない場合、終日いつでも届く可能性があります"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "💡 시간대를 지정하지 않으면 하루 종일 언제든지 도착할 수 있습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "💡如果不指定时间段，可能一天中的任何时间到达"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "💡如果不指定時間段，可能一天中的任何時間到達"
          }
        }
      }
    },
    "💡 期間を指定しない場合、1日後〜3年後の間でサプライズ配達されます": {
      "comment": "Literal from lifelog/Views/Letter/LetterEditorView.swift",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "💡 If you do not specify a period, surprise delivery will be made between 1 day and 3 years later."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "💡 期間を指定しない場合、1日後〜3年後の間でサプライズ配達されます"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "💡 기간을 지정하지 않으면 1일에서 3년 사이에 깜짝 배달됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "💡如果不指定期限，1天到3年后会惊喜发货。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "💡如果不指定期限，1天到3年後會驚喜出貨。"
          }
        }
      }
    },
