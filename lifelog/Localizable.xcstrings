            "value": "%@さんから手紙が届いています"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@님으로부터 편지를 받았습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
