          }
        }
      }
    },
    "%@さんと友達になりました！\n\n設定 → ひみつの機能 → 大切な人への手紙\nからいつでも手紙が書けます": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I became friends with %@!\n\nSettings → Secret functions → Letters to loved ones\nYou can write a letter anytime from"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@さんと友達になりました！\n\n設定 → ひみつの機能 → 大切な人への手紙\nからいつでも手紙が書けます"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@님과 친구가 되었습니다!\n\n설정 → 비밀 기능 → 소중한 사람에게 보내는 편지\n언제든지 편지를 쓸 수 있습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "我和%@成为了朋友！\n\n设置 → 秘密功能 → 给亲人的信\n您可以随时写信"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "我和%@成為朋友了！\n\n設定 → 秘密功能 → 給親人的信\n您可以隨時寫信"
          }
        }
      }
    },
    "%@さんより": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "From %@"
          }
        },
        "ja": {
