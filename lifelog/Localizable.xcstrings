        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この端末にはパスコードまたはFace ID / Touch IDが設定されていません。iOSの「設定」でパスコードを設定してからお試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 기기에는 패스코드나 Face ID/Touch ID가 설정되어 있지 않습니다. iOS의 '설정'에서 비밀번호를 설정한 후 사용해 보세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
